// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String?  @unique
  firstName String?
  lastName  String?
  phoneNumber String?
  birthDate DateTime?
  role      UserRole @default(USER)
  trainingCategory      TrainingCategory @default(B)
  isAccountActive       Boolean @default(false)
  isRegistrationComplete Boolean @default(false)
  trainingHoursCompleted Int @default(0)
  trainingHoursRequired  Int @default(30)
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  pkkFile   PkkFile?
  instructorAssignmentsAsInstructor InstructorStudentAssignment[] @relation("InstructorAssignments")
  instructorAssignmentsAsStudent InstructorStudentAssignment[] @relation("StudentAssignments")
  drivingLessonsAsInstructor DrivingLesson[] @relation("InstructorLessons")
  drivingLessonsAsStudent DrivingLesson[] @relation("StudentLessons")

  @@index([clerkId])
}

enum UserRole {
  USER
  ADMINISTRATOR
  INSTRUKTOR
}

enum TrainingCategory {
  A
  B
}

enum AnnouncementAudience {
  ALL_KURSANCI
  KURSANCI_KAT_A
  KURSANCI_KAT_B
  KURSANCI_OCZEKUJACY
  INSTRUKTORZY
}

enum CourseCategory {
  A
  B
  DOSZKALANIE
}

enum CourseStatus {
  NABOR
  PLANOWANY
  STALA_OFERTA
}

model Announcement {
  id         String   @id @default(cuid())
  title      String
  content    String
  target     AnnouncementAudience @default(ALL_KURSANCI)
  authorName String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([createdAt])
}

model PkkFile {
  id               String   @id @default(cuid())
  userId           String   @unique
  objectKey        String   @unique
  originalFileName String
  contentType      String
  sizeBytes        Int
  sha256           String
  uploadedAt       DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Course {
  id            String       @id @default(cuid())
  title         String
  category      CourseCategory
  startDate     DateTime?
  duration      String
  pricePln      Int
  enrolledCount Int          @default(0)
  capacity      Int?
  status        CourseStatus @default(NABOR)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([createdAt])
  @@index([status])
}

enum DrivingLessonStatus {
  PLANOWANA
  ZREALIZOWANA
  ODWOLANA
}

model InstructorStudentAssignment {
  id           String   @id @default(cuid())
  instructorId String
  studentId    String
  note         String?
  isActive     Boolean  @default(true)
  assignedAt   DateTime @default(now())
  updatedAt    DateTime @updatedAt

  instructor User @relation("InstructorAssignments", fields: [instructorId], references: [id], onDelete: Cascade)
  student    User @relation("StudentAssignments", fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([instructorId, studentId])
  @@index([instructorId, isActive])
  @@index([studentId, isActive])
}

model DrivingLesson {
  id               String            @id @default(cuid())
  studentId        String
  instructorId     String
  startsAt         DateTime?
  durationMinutes  Int               @default(60)
  topic            String
  routeSummary     String?
  instructorFeedback String?
  routeScore       Int?
  status           DrivingLessonStatus @default(PLANOWANA)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  student    User @relation("StudentLessons", fields: [studentId], references: [id], onDelete: Cascade)
  instructor User @relation("InstructorLessons", fields: [instructorId], references: [id], onDelete: Cascade)

  @@index([studentId, startsAt])
  @@index([instructorId, startsAt])
  @@index([status])
}
